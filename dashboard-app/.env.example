# DB 接続先。以下のいずれかを選ぶ（Next.js は .env.local > .env の優先で読む）
#
# 1) ローカル Docker (docker compose up -d で m5postgres を起動)
# DATABASE_URL="postgresql://tamanegi:tamanegi@localhost:5411/tamanegi"
#
# 2) Prisma Postgres (managed, https://console.prisma.io)
# DATABASE_URL="postgres://USER:API_KEY@db.prisma.io:5432/postgres?sslmode=verify-full"
#
# 3) その他の managed Postgres
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=verify-full"
DATABASE_URL="postgresql://tamanegi:tamanegi@localhost:5411/tamanegi"
API_KEY=change-me-to-a-long-random-string
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxxxxxxxxxx/yyyyyyyyyyyyyyyyyyyyyyyyyyyyy
ALERT_HIGH_PPM=1200
ALERT_CLEAR_PPM=900
ALERT_COOLDOWN_MS=600000
