generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Reading {
  id         Int     @id @default(autoincrement())
  deviceId   String  @map("device_id")
  ppm        Int
  recordedAt BigInt  @map("recorded_at")
  fw         String?

  @@index([deviceId, recordedAt(sort: Desc)], map: "idx_readings_device_time")
  @@map("readings")
}

model Device {
  deviceId    String  @id @map("device_id")
  displayName String? @map("display_name")
  lastSeenAt  BigInt? @map("last_seen_at")
  lastPpm     Int?    @map("last_ppm")

  @@map("devices")
}

model AlertState {
  deviceId    String  @id @map("device_id")
  inAlert     Int     @default(0) @map("in_alert")
  lastFiredAt BigInt? @map("last_fired_at")

  @@map("alert_state")
}
